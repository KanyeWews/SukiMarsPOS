<Window x:Class="SukiMars.RoleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SukiMars Dashboard"
        Height="900"
        Width="1450"
        WindowStartupLocation="CenterScreen"
        Background="#FFF3F4F6">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1F2937">
            <StackPanel Margin="16">
                <TextBlock Text="SukiMars Cart"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0,8,0,2" />
                <TextBlock x:Name="CurrentUserText"
                           Foreground="#D1D5DB"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,16" />

                <Button x:Name="CashierButton"
                        Content="Cashier POS"
                        Height="42"
                        Margin="0,0,0,8"
                        Click="CashierButton_Click" />
                <Button x:Name="InventoryButton"
                        Content="Manage Inventory"
                        Height="42"
                        Margin="0,0,0,8"
                        Click="InventoryButton_Click" />
                <Button x:Name="ReportsButton"
                        Content="Analytical Report"
                        Height="42"
                        Margin="0,0,0,8"
                        Click="ReportsButton_Click" />
                <Button x:Name="UsersButton"
                        Content="User Management"
                        Height="42"
                        Margin="0,0,0,20"
                        Click="UsersButton_Click" />

                <Button Content="Log Out"
                        Height="42"
                        Foreground="White"
                        Background="#DC2626"
                        BorderBrush="#DC2626"
                        Click="LogoutButton_Click" />
            </StackPanel>
        </Border>

        <Frame x:Name="ContentFrame"
               Grid.Column="1"
               Margin="12"
               NavigationUIVisibility="Hidden" />
    </Grid>
</Window>
