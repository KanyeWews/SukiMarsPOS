<Page x:Class="SukiMars.Views.AdminUsersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="AdminUsersPage"
      Background="#FFF3F4F6">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#c2f7c8" CornerRadius="12" Padding="16" Margin="0,0,0,14">
            <DockPanel>
                <TextBlock Text="SukiMars Cart - Administrator Panel" FontWeight="Bold" FontSize="22" Foreground="Black" DockPanel.Dock="Left" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="SearchUserBox" Grid.Column="0" Height="38" VerticalContentAlignment="Center" Text="Search User..." />
            <Button x:Name="SearchUserButton" Grid.Column="2" Content="Search" Height="38" Padding="12,6" />
            <Button Grid.Column="4" Content="+ Add User" Margin="12,0,0,0" Padding="16,6" Click="AddUser_Click" />
        </Grid>

        <UniformGrid Grid.Row="2" Rows="1" Columns="3" Margin="0,0,0,10">
            <Border Background="White" Margin="6" Padding="14" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Total Users"/>
                    <TextBlock Text="0" FontSize="24" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Background="White" Margin="6" Padding="14" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Active"/>
                    <TextBlock Text="0" FontSize="24" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Background="White" Margin="6" Padding="14" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Inactive"/>
                    <TextBlock Text="0" FontSize="24" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <DataGrid x:Name="UsersGrid" Grid.Row="3" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Col1}" Width="*" />
                <DataGridTextColumn Header="Username" Binding="{Binding Col2}" Width="*" />
                <DataGridTextColumn Header="Role" Binding="{Binding Col3}" Width="*" />
                <DataGridTextColumn Header="Status" Binding="{Binding Col4}" Width="*" />
                <DataGridTextColumn Header="Actions" Binding="{Binding Col5}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
