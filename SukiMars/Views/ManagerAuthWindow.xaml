<Window x:Class="SukiMars.Views.ManagerAuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manager Authorization"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow">
    <Border Padding="24" Background="White" CornerRadius="6">
        <StackPanel Width="320">
            <TextBlock Text="Manager Authorization" FontWeight="Bold" FontSize="16" Margin="0,0,0,6" />
            <TextBlock Text="Enter your manager PIN to continue." FontSize="12" Foreground="#6B7280" Margin="0,0,0,16" />

            <TextBlock Text="PIN Code" FontWeight="SemiBold" FontSize="12" Foreground="#374151" Margin="0,0,0,4" />
            <PasswordBox x:Name="PincodeInput" Margin="0,0,0,4" FontSize="14" Padding="8,6" />

            <TextBlock x:Name="AuthErrorText" Foreground="#B91C1C" FontSize="12" Margin="0,0,0,10" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="80" Margin="0,0,8,0" Click="Cancel_Click" />
                <Button Content="Authorize" Width="100" Background="#0B6B3C" Foreground="White" Click="Authorize_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
