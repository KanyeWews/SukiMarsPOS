<Window x:Class="SukiMars.Views.ManagerAuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manager Authorization"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow">
    <Border Padding="16" Background="White" CornerRadius="6">
        <StackPanel Width="360">
            <TextBlock Text="Manager credentials required" FontWeight="Bold" FontSize="14" Margin="0,0,0,12" />

            <TextBlock Text="Username" />
            <TextBox x:Name="UsernameInput" Margin="0,4,0,8" />

            <TextBlock Text="Password" />
            <PasswordBox x:Name="PasswordInput" Margin="0,4,0,8" />

            <TextBlock Text="Pincode" />
            <TextBox x:Name="PincodeInput" Margin="0,4,0,8" />

            <TextBlock x:Name="AuthErrorText" Foreground="#B91C1C" Margin="0,4,0,8" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="80" Margin="0,0,8,0" Click="Cancel_Click" />
                <Button Content="Authorize" Width="100" Click="Authorize_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
