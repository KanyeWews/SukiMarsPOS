<Page x:Class="SukiMars.Views.NewOrderPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="NewOrderPage"
      Background="#FFF3F4F6">

    <Page.Resources>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F9FAFB" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="BorderBrush" Value="#E5E7EB" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E5E7EB" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F3F4F6" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header banner -->
        <Border Grid.Row="0" Background="#c2f7c8" CornerRadius="12" Padding="16" Margin="0,0,0,14">
            <DockPanel>
                <TextBlock Text="Create New Purchase Order"
                           FontWeight="Bold" FontSize="22" Foreground="Black" DockPanel.Dock="Left"
                           VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="← Back to Warehouse" Padding="14,6" Cursor="Hand"
                            Background="Transparent" BorderThickness="0" Foreground="#047857"
                            FontWeight="SemiBold" Click="Cancel_Click" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main content: two columns -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.4*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: Order details + Add items -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Order Details card -->
                <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="18" Margin="0,0,0,12"
                        BorderBrush="#E5E7EB" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Order Details" FontSize="16" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,14" />
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Supplier" FontWeight="SemiBold" FontSize="12" Foreground="#374151" Margin="0,0,0,6" />
                                <ComboBox x:Name="SupplierCombo" Height="36" FontSize="13"
                                          VerticalContentAlignment="Center" DisplayMemberPath="SupplierName" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Est. Delivery Date" FontWeight="SemiBold" FontSize="12" Foreground="#374151" Margin="0,0,0,6" />
                                <DatePicker x:Name="EstDeliveryDate" Height="36" FontSize="13"
                                            VerticalContentAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Add Items card -->
                <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="18" Margin="0,0,0,12"
                        BorderBrush="#E5E7EB" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Add Items" FontSize="16" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,14" />
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="SkuCombo" Grid.Column="0" Height="36" FontSize="13"
                                      VerticalContentAlignment="Center" SelectedValuePath="ItemId">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding ItemCode}" FontWeight="SemiBold" Width="130" />
                                            <TextBlock Text=" — " Foreground="#9CA3AF" />
                                            <TextBlock Text="{Binding ItemName}" Foreground="#374151" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBox x:Name="QtyInput" Grid.Column="2" Height="36" FontSize="13"
                                     VerticalContentAlignment="Center" ToolTip="Quantity" />
                            <Button Grid.Column="4" Content="+ Add" Padding="16,0" Height="36"
                                    Background="#0B6B3C" Foreground="White" FontWeight="SemiBold"
                                    BorderThickness="0" Cursor="Hand" Click="AddItem_Click" />
                        </Grid>
                    </Grid>
                </Border>

                <!-- Comments card -->
                <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="18" Margin="0,0,0,12"
                        BorderBrush="#E5E7EB" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Comments" FontSize="16" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,10" />
                        <TextBox x:Name="CommentsBox" Height="70" AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" FontSize="13" Padding="8"
                                 ToolTip="Add notes about this order (optional)" />
                    </StackPanel>
                </Border>

                <!-- Processed Orders (Recent) -->
                <Border Grid.Row="3" Background="White" CornerRadius="8" Padding="18"
                        BorderBrush="#E5E7EB" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Recent Orders" FontSize="16" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,12" />
                        <DataGrid x:Name="ProcessedOrdersGrid" Grid.Row="1"
                                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                  HeadersVisibility="Column" GridLinesVisibility="None"
                                  Background="White" BorderThickness="0" RowHeaderWidth="0"
                                  RowHeight="42" ColumnHeaderHeight="40">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ASN" Binding="{Binding ASNNumber}" Width="120" />
                                <DataGridTextColumn Header="Item" Binding="{Binding ItemName}" Width="*" />
                                <DataGridTextColumn Header="SKU" Binding="{Binding ItemCode}" Width="120" />
                                <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="60" />
                                <DataGridTextColumn Header="Supplier" Binding="{Binding Supplier}" Width="140" />
                                <DataGridTextColumn Header="Est. Delivery" Binding="{Binding EstimatedDeliveryDate, StringFormat='{}{0:MMM d, yyyy}'}" Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <!-- RIGHT: Current Order summary -->
            <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="18"
                    BorderBrush="#E5E7EB" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Current Order" FontSize="18" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,4" />
                    <TextBlock x:Name="ItemCountText" Grid.Row="1" Text="0 items" FontSize="13" Foreground="#6B7280" Margin="0,0,0,14" />

                    <DataGrid x:Name="CurrentOrderGrid" Grid.Row="2"
                              AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="None"
                              Background="White" BorderThickness="0" RowHeaderWidth="0"
                              RowHeight="42" ColumnHeaderHeight="40">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Item" Binding="{Binding ItemName}" Width="*" />
                            <DataGridTextColumn Header="SKU" Binding="{Binding ItemCode}" Width="110" />
                            <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="55" />
                            <DataGridTemplateColumn Header="" Width="40">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✕" FontSize="12" Foreground="#DC2626"
                                                Background="Transparent" BorderThickness="0"
                                                Cursor="Hand" Tag="{Binding}"
                                                Click="RemoveItem_Click" ToolTip="Remove item" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="3" Margin="0,14,0,0">
                        <Button Content="Process Order" Height="42"
                                Background="#0B6B3C" Foreground="White" FontWeight="Bold" FontSize="14"
                                BorderThickness="0" Cursor="Hand" Margin="0,0,0,8"
                                Click="ConfirmButton_Click" />
                        <Button Content="Clear All Items" Height="36"
                                Background="#FEE2E2" Foreground="#DC2626" FontWeight="SemiBold"
                                BorderThickness="0" Cursor="Hand"
                                Click="ClearItems_Click" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
