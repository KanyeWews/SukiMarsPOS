<Page x:Class="SukiMars.Views.SignUpPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="SignUpPage"
      Background="#c2f7c8"> <!-- Make page background green so top-left corner is green -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.1*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#c2f7c8" Margin="-12,0,0,0">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Margin="32">
                <Image Source="file:///C:/Users/zulea/.cursor/projects/C-Users-zulea-AppData-Local-Temp-590f3eb9-56a6-4f56-945c-11be47c33920/assets/c__Users_zulea_AppData_Roaming_Cursor_User_workspaceStorage_1777426078862_images_image-c0abb9e3-0bcc-4c90-926a-d06f4e89f90e.png"
                       Width="280"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20" />
                <TextBlock Text="SukiMars Cart"
                           FontSize="54"
                           FontWeight="Bold"
                           Foreground="Black"
                           TextAlignment="Center"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Presyong Suki, Alagang Mars"
                           Margin="0,12,0,0"
                           FontSize="24"
                           Foreground="Black"
                           TextAlignment="Center"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Background="#FFF8FAFC"> <!-- Ensure the right column keeps the light background -->
            <Border Width="470"
                    Padding="30"
                    Background="White"
                    CornerRadius="18"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock x:Name="HeaderText" Text="Create Account"
                               FontSize="30"
                               FontWeight="Bold"
                               Margin="0,0,0,18" />

                    <TextBlock Text="First Name" FontWeight="SemiBold" />
                    <TextBox x:Name="FirstNameInput" Height="36" Margin="0,6,0,10" />

                    <TextBlock Text="Last Name" FontWeight="SemiBold" />
                    <TextBox x:Name="LastNameInput" Height="36" Margin="0,6,0,12" />

                    <TextBlock Text="Username" FontWeight="SemiBold" />
                    <TextBox x:Name="UsernameInput" Height="40" Margin="0,6,0,12" TextChanged="UsernameInput_TextChanged" />

                    <TextBlock Text="Password" FontWeight="SemiBold" />
                    <PasswordBox x:Name="PasswordInput" Height="40" Margin="0,6,0,12" />

                    <TextBlock Text="Re Enter Password" FontWeight="SemiBold" />
                    <PasswordBox x:Name="ConfirmPasswordInput" Height="40" Margin="0,6,0,12" />

                    <TextBlock Text="Pincode (max 4 digits)" FontWeight="SemiBold" />
                    <TextBox x:Name="PincodeInput" Height="36" Margin="0,6,0,12" MaxLength="4"
                             PreviewTextInput="PincodeInput_PreviewTextInput" />

                    <TextBlock Text="Choose your Role" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,20">
                        <RadioButton x:Name="CashierRoleRadio" Content="Cashier" IsChecked="True" Margin="0,0,24,0" />
                        <RadioButton x:Name="ManagerRoleRadio" Content="Manager" Margin="0,0,24,0" />
                        <RadioButton x:Name="AdminRoleRadio" Content="Admin" />
                    </StackPanel>

                    <Button x:Name="SubmitButton"
                            Content="Create Account"
                            Height="44"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Background="#004524"
                            BorderBrush="#004524"
                            Click="CreateAccount_Click" />
                    <TextBlock x:Name="SignUpMessageText"
                               Margin="0,12,0,0"
                               Foreground="#B91C1C"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
