<Page x:Class="SukiMars.Views.InventoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="InventoryPage"
      Background="#FFF3F4F6">
    <Grid>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#c2f7c8" CornerRadius="12" Padding="16" Margin="0,0,0,14">
            <DockPanel>
                <TextBlock Text="SukiMars Cart - Inventory" FontWeight="Bold" FontSize="22" Foreground="Black" DockPanel.Dock="Left" />
            </DockPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <!-- Search & Actions -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SearchBox"
                         Grid.Column="0"
                         Height="38"
                         FontSize="12"
                         VerticalContentAlignment="Center"
                         Text="Search product..."
                         Foreground="Gray"
                         GotFocus="SearchBox_GotFocus"
                         LostFocus="SearchBox_LostFocus" />
                <Button Grid.Column="2" Content="Search" Click="Search_Click" />
                <Button Grid.Column="4" Content="Refresh" Click="Refresh_Click" />
                <Button Grid.Column="5" Content="+ Add Product" Padding="14,6" HorizontalAlignment="Right" Click="AddProductModal_Click" />
            </Grid>
            <!-- Filters -->
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Filter by:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,12,0"/>
                
                <ComboBox x:Name="FilterROP" Width="120" Margin="0,0,12,0" SelectionChanged="Filter_SelectionChanged">
                    <ComboBoxItem Content="All ROP" IsSelected="True"/>
                    <ComboBoxItem Content="Good"/>
                    <ComboBoxItem Content="Warning"/>
                    <ComboBoxItem Content="Critical"/>
                </ComboBox>

                <ComboBox x:Name="FilterProductType" Width="140" Margin="0,0,12,0" SelectionChanged="Filter_SelectionChanged">
                    <ComboBoxItem Content="All Types" IsSelected="True"/>
                    <ComboBoxItem Content="Perishable"/>
                    <ComboBoxItem Content="Non-Perishable"/>
                </ComboBox>

                <ComboBox x:Name="FilterCategory" Width="150" Margin="0,0,12,0" SelectionChanged="Filter_SelectionChanged">
                    <ComboBoxItem Content="All Categories" IsSelected="True"/>
                </ComboBox>
                
                <TextBlock x:Name="InventoryMessageText" VerticalAlignment="Center" Foreground="#B91C1C" Margin="12,0,0,0" />
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <UniformGrid Rows="1" Columns="4" Margin="0,0,0,12">
                <Border Background="White" Margin="6" Padding="14" CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="Total Product/s"/>
                        <TextBlock x:Name="TotalProductsText" Text="0" FontSize="26" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Background="White" Margin="6" Padding="14" CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="Low Stock"/>
                        <TextBlock x:Name="LowStockText" Text="0" FontSize="26" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Background="White" Margin="6" Padding="14" CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="Out of Stock"/>
                        <TextBlock x:Name="OutOfStockText" Text="0" FontSize="26" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Background="White" Margin="6" Padding="14" CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="Categories"/>
                        <TextBlock x:Name="CategoriesText" Text="0" FontSize="26" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Grid.Row="1">
                <DataGrid x:Name="InventoryGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Product Name" Binding="{Binding ItemName}" Width="*" />
                        <DataGridTextColumn Header="Code" Binding="{Binding ItemCode}" Width="*" />
                        <DataGridTextColumn Header="Category" Binding="{Binding ItemCategory}" Width="*" />
                        <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="*" />
                        <DataGridTextColumn Header="Stock" Binding="{Binding CurrentQty}" Width="*" />

                        <DataGridTemplateColumn Header="Reorder point (ROP)" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Ellipse Width="16" Height="16">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="Gray" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ReorderLevel}" Value="Good">
                                                            <Setter Property="Fill" Value="Green" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ReorderLevel}" Value="Warning">
                                                            <Setter Property="Fill" Value="Yellow" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ReorderLevel}" Value="Critical">
                                                            <Setter Property="Fill" Value="Red" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Type" Binding="{Binding ProductType}" Width="*" />
                        <DataGridTextColumn Header="Expiration Date" Binding="{Binding ExpirationDateDisplay}" Width="*" />
                        <DataGridTextColumn Header="Shelf Life" Binding="{Binding ShelfLifeDisplay}" Width="*" />
                        <DataGridTextColumn Header="Expiration Status" Binding="{Binding ExpirationStatus}" Width="*" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*" />

                        <!-- View + Edit actions -->
                        <DataGridTemplateColumn Header="Actions" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="View" Foreground="#059669" Background="Transparent"
                                                BorderThickness="0" Cursor="Hand" Margin="0,0,8,0"
                                                Click="ViewProduct_Click" />
                                        <Button Content="Edit" Foreground="#2563EB" Background="Transparent"
                                                BorderThickness="0" Cursor="Hand"
                                                Click="EditProduct_Click" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </Grid>

    <!-- ===== ADD / EDIT Product Modal ===== -->
    <Grid x:Name="ProductModalOverlay" Visibility="Collapsed">
        <Border Background="#80000000" />
        <Border Background="White" CornerRadius="10" Padding="24"
                Width="420" VerticalAlignment="Center" HorizontalAlignment="Center"
                BorderBrush="#D1D5DB" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" Opacity="0.25" ShadowDepth="4" />
            </Border.Effect>
            <StackPanel>
                <TextBlock x:Name="ModalTitle" Text="Add Product" FontSize="18" FontWeight="Bold" Margin="0,0,0,16" />

                <!-- Name + Code/SKU -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Product Name" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <TextBox x:Name="ModalNameInput" Height="34" VerticalContentAlignment="Center" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Code / SKU" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <TextBox x:Name="ModalCodeInput" Height="34" VerticalContentAlignment="Center" />
                    </StackPanel>
                </Grid>

                <!-- Product Type + Category -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Product Type" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <ComboBox x:Name="ModalProductTypeInput" Height="34" VerticalContentAlignment="Center">
                            <ComboBoxItem Content="Non-Perishable" IsSelected="True"/>
                            <ComboBoxItem Content="Perishable"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Category" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <TextBox x:Name="ModalCategoryInput" Height="34" VerticalContentAlignment="Center" />
                    </StackPanel>
                </Grid>

                <!-- Price + Shelf Life -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Price" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <TextBox x:Name="ModalPriceInput" Height="34" VerticalContentAlignment="Center" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" x:Name="ModalShelfLifePanel" Visibility="Visible">
                        <TextBlock Text="Shelf Life (Days)" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <TextBox x:Name="ModalShelfLifeInput" Height="34" VerticalContentAlignment="Center" />
                    </StackPanel>
                </Grid>

                <!-- Description -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Description" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBox x:Name="ModalDescriptionInput" AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" Height="80" Padding="8" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Padding="16,6" Margin="0,0,10,0" Click="ModalCancel_Click" />
                    <Button x:Name="ModalSaveBtn" Content="Save" Padding="16,6" Background="#0B6B3C" Foreground="White" Click="ModalSave_Click" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>

    <!-- ===== VIEW Details Modal ===== -->
    <Grid x:Name="ViewModalOverlay" Visibility="Collapsed">
        <Border Background="#80000000" />
        <Border Background="White" CornerRadius="10" Padding="28"
                Width="480" VerticalAlignment="Center" HorizontalAlignment="Center"
                BorderBrush="#D1D5DB" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18" Opacity="0.22" ShadowDepth="4" />
            </Border.Effect>
            <StackPanel>
                <!-- Header -->
                <DockPanel Margin="0,0,0,16">
                    <TextBlock Text="Product Details" FontSize="18" FontWeight="Bold" DockPanel.Dock="Left" />
                    <Button Content="✕" DockPanel.Dock="Right" HorizontalAlignment="Right"
                            Background="Transparent" BorderThickness="0" FontSize="16"
                            Foreground="#6B7280" Cursor="Hand" Click="ViewModalClose_Click" />
                </DockPanel>

                <!-- Barcode image centred at top -->
                <Border Background="#F9FAFB" CornerRadius="8" Padding="16,12" Margin="0,0,0,16"
                        BorderBrush="#E5E7EB" BorderThickness="1">
                    <StackPanel>
                        <Image x:Name="ViewBarcodeImage" Height="80" HorizontalAlignment="Center"
                               Stretch="Uniform" Margin="0,0,0,6" />
                        <TextBlock x:Name="ViewBarcodeValueText" FontSize="12" Foreground="#374151"
                                   HorizontalAlignment="Center" FontFamily="Consolas" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                            <Button Content="🖨 Print Barcode" Padding="10,4" FontSize="11"
                                    Margin="0,0,8,0" Click="ViewPrintBarcode_Click" />
                            <Button Content="💾 Save PNG" Padding="10,4" FontSize="11"
                                    Click="ViewSaveBarcode_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Detail rows -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Product Name" FontWeight="SemiBold" Foreground="#6B7280" Padding="0,6" />
                    <TextBlock x:Name="ViewNameText"   Grid.Row="0" Grid.Column="1" Padding="0,6" TextWrapping="Wrap" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Code / SKU"    FontWeight="SemiBold" Foreground="#6B7280" Padding="0,6" />
                    <TextBlock x:Name="ViewCodeText"   Grid.Row="1" Grid.Column="1" Padding="0,6" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Category"      FontWeight="SemiBold" Foreground="#6B7280" Padding="0,6" />
                    <TextBlock x:Name="ViewCategoryText" Grid.Row="2" Grid.Column="1" Padding="0,6" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Price"         FontWeight="SemiBold" Foreground="#6B7280" Padding="0,6" />
                    <TextBlock x:Name="ViewPriceText"  Grid.Row="3" Grid.Column="1" Padding="0,6" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Stock"         FontWeight="SemiBold" Foreground="#6B7280" Padding="0,6" />
                    <TextBlock x:Name="ViewStockText"  Grid.Row="4" Grid.Column="1" Padding="0,6" />

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Product Type"  FontWeight="SemiBold" Foreground="#6B7280" Padding="0,6" />
                    <TextBlock x:Name="ViewTypeText"   Grid.Row="5" Grid.Column="1" Padding="0,6" />

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Expiry Date"   FontWeight="SemiBold" Foreground="#6B7280" Padding="0,6" />
                    <TextBlock x:Name="ViewExpiryText" Grid.Row="6" Grid.Column="1" Padding="0,6" />

                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Shelf Life"    FontWeight="SemiBold" Foreground="#6B7280" Padding="0,6" />
                    <TextBlock x:Name="ViewShelfText"  Grid.Row="7" Grid.Column="1" Padding="0,6" />

                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Status"        FontWeight="SemiBold" Foreground="#6B7280" Padding="0,6" />
                    <TextBlock x:Name="ViewStatusText" Grid.Row="8" Grid.Column="1" Padding="0,6" />

                    <TextBlock Grid.Row="9" Grid.Column="0" Text="Description"   FontWeight="SemiBold" Foreground="#6B7280" Padding="0,6" VerticalAlignment="Top" />
                    <TextBlock x:Name="ViewDescText"   Grid.Row="9" Grid.Column="1" Padding="0,6" TextWrapping="Wrap" />
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                    <Button Content="Close" Padding="16,6" Click="ViewModalClose_Click" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>

    </Grid>
</Page>