<Page x:Class="SukiMars.Views.InventoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="InventoryPage"
      Background="#FFF3F4F6">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#c2f7c8" CornerRadius="12" Padding="16" Margin="0,0,0,14">
            <DockPanel>
                <TextBlock Text="SukiMars Cart - Inventory" FontWeight="Bold" FontSize="22" Foreground="Black" DockPanel.Dock="Left" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="130" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="130" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="130" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="SearchBox"
                     Grid.Column="0"
                     Height="38"
                     FontSize="12"
                     VerticalContentAlignment="Center"
                     Text="Search product..."
                     Foreground="Gray"
                     GotFocus="SearchBox_GotFocus"
                     LostFocus="SearchBox_LostFocus" />
            <Button Grid.Column="2" Content="Search" Click="Search_Click" />
            <Button Grid.Column="4" Content="Refresh" Click="Refresh_Click" />
            <Button Grid.Column="6" Content="Delete" Background="#DC2626" Foreground="White" BorderBrush="#DC2626" Click="Delete_Click" />
            <TextBlock x:Name="InventoryMessageText" Grid.Column="8" VerticalAlignment="Center" Foreground="#B91C1C" />
        </Grid>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <UniformGrid Rows="1" Columns="4" Margin="0,0,0,12">
                <Border Background="White" Margin="6" Padding="14" CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="Total Product/s"/>
                        <TextBlock x:Name="TotalProductsText" Text="0" FontSize="26" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Background="White" Margin="6" Padding="14" CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="Low Stock"/>
                        <TextBlock x:Name="LowStockText" Text="0" FontSize="26" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Background="White" Margin="6" Padding="14" CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="Out of Stock"/>
                        <TextBlock x:Name="OutOfStockText" Text="0" FontSize="26" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Background="White" Margin="6" Padding="14" CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="Categories"/>
                        <TextBlock x:Name="CategoriesText" Text="0" FontSize="26" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DataGrid x:Name="InventoryGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          SelectionChanged="InventoryGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Product Name" Binding="{Binding ItemName}" Width="*" />
                        <DataGridTextColumn Header="Code" Binding="{Binding ItemCode}" Width="*" />
                        <DataGridTextColumn Header="Category" Binding="{Binding ItemCategory}" Width="*" />
                        <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="*" />
                        <DataGridTextColumn Header="Stock" Binding="{Binding CurrentQty}" Width="*" />

                        <DataGridTemplateColumn Header="Reorder point (ROP)" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Ellipse Width="16" Height="16">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="Gray" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ReorderLevel}" Value="Good">
                                                            <Setter Property="Fill" Value="Green" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ReorderLevel}" Value="Warning">
                                                            <Setter Property="Fill" Value="Yellow" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ReorderLevel}" Value="Critical">
                                                            <Setter Property="Fill" Value="Red" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="1" Margin="0,10,0,0" Padding="12" CornerRadius="8" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Product Name" FontWeight="SemiBold" Margin="0,0,8,6" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Code / SKU" FontWeight="SemiBold" Margin="0,0,8,6" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Category" FontWeight="SemiBold" Margin="0,0,8,6" />
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Price" FontWeight="SemiBold" Margin="0,0,8,6" />

                        <TextBox x:Name="NameInput" Grid.Row="1" Grid.Column="0" Margin="0,0,8,0" Height="34" VerticalContentAlignment="Center" ToolTip="Example: Coke 1L" />
                        <TextBox x:Name="CodeInput" Grid.Row="1" Grid.Column="1" Margin="0,0,8,0" Height="34" VerticalContentAlignment="Center" ToolTip="Example: BEV-COKE-1L" />
                        <TextBox x:Name="CategoryInput" Grid.Row="1" Grid.Column="2" Margin="0,0,8,0" Height="34" VerticalContentAlignment="Center" ToolTip="Example: Beverages" />
                        <TextBox x:Name="PriceInput" Grid.Row="1" Grid.Column="3" Margin="0,0,8,0" Height="34" VerticalContentAlignment="Center" ToolTip="Example: 55.00" />

                        <Button Grid.Row="1" Grid.Column="5" Content="+ Add Product" Padding="14,6" Click="Add_Click" />
                        <Button Grid.Row="1" Grid.Column="7" Content="Update Selected" Padding="14,6" Click="Update_Click" />

                        <TextBlock Grid.Row="2"
                                   Grid.ColumnSpan="8"
                                   Margin="0,8,0,0"
                                   Foreground="#6B7280"
                                   FontSize="12"
                                   Text="Note: Select a row above to auto-fill these fields, then click 'Update Selected'. For new items, fill all fields then click '+ Add Product'." />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>